  },
  "keywords": ["tcts", "telemetry", "llm", "budget", "mission-control"],
  "license": "UNLICENSED",
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
